<?xml version="1.0" encoding="UTF-8" ?>

<c:unit xpl:outputMode="node">
    <c:import from="/nop/excel/xlib/export-gen.xlib"/>

    <c:script>
        const exportPo = { ...po, props: po.props.filter(p => p.tagSet == null || (',' + p.tagSet + ',').contains(',io,')) };
    </c:script>

    <export-gen:GenWorkbook po="${exportPo}" data="${data}"/>
</c:unit>
